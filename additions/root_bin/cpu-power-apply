#!/usr/bin/env bash
# usage: cpu-power-apply [busy|idle|auto]   (auto = decide from this node's Slurm CPUAlloc)
set -uo pipefail

MODE="${1:-auto}"

if [[ "${MODE}" == auto ]]; then
    alloc=$(scontrol -o show node "$(hostname -s)" 2>/dev/null | grep -oP 'CPUAlloc=\K[0-9]+')
    if [[ -z "${alloc}" ]]; then
        echo "cpu-power-apply: cannot read CPUAlloc for $(hostname -s); leaving profile unchanged" >&2
        exit 1
    fi
    (( alloc > 0 )) && MODE=busy || MODE=idle
fi

case "${MODE}" in
    busy) GOV=performance; EPP=performance ;;
    idle) GOV=powersave;   EPP=power       ;;
    *)    echo "usage: $0 [busy|idle|auto]" >&2; exit 2 ;;
esac

# 1) Governor: universal across all drivers in this fleet.
cpupower -c all frequency-set -g "${GOV}" >/dev/null 2>&1

# 1b) Keep CPB/boost enabled so 'performance' can clock above base (global knob).
[[ -w /sys/devices/system/cpu/cpufreq/boost ]] && echo 1 > /sys/devices/system/cpu/cpufreq/boost 2>/dev/null

# 2) Per-policy: reset clamps to hardware bounds, set EPP only where exposed.
for pol in /sys/devices/system/cpu/cpu*/cpufreq; do
    [[ -r "${pol}/cpuinfo_min_freq" ]] || continue
    fmin=$(< "${pol}/cpuinfo_min_freq")
    fmax=$(< "${pol}/cpuinfo_max_freq")
    echo "${fmin}" > "${pol}/scaling_min_freq" 2>/dev/null   # floor first
    echo "${fmax}" > "${pol}/scaling_max_freq" 2>/dev/null   # then ceiling
    if [[ -w "${pol}/energy_performance_preference" ]]; then
        echo "${EPP}" > "${pol}/energy_performance_preference" 2>/dev/null
    fi
done

